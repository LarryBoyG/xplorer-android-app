<resources xmlns:tools="http://schemas.android.com/tools">
    <style name="Theme.XiroLite" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@color/xiro_background</item>
        <item name="android:windowBackground">@color/xiro_background</item>
    </style>

    <style name="Theme.XiroLite.Splash" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="android:windowBackground">@color/xiro_background</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@color/xiro_background</item>
        <item name="android:windowFullscreen">true</item>
    </style>
</resources>
